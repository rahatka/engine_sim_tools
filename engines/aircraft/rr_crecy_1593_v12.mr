import "engine_sim.mr"
import "../../fuel/30.mr"

units units()
constants constants()

label vee(rot90)
label bore(129.54) // 5.1
label stroke(165.1) // 6.5
label compression_ratio(7.0)
label con_rod(279.4) // 11 ?
label compression_height(bore / 2 * units.mm) // ?
label intake_valve_diameter(113.14) // 406.962 / 2 * 49.53 area
label exhaust_valve_diameter(113.14) // ?
label intake_valves(1.0)
label exhaust_valves(1.0)

label redline(3000.0) // RPM

label cyl(12.0)
label row(2.0)
label cycle(rot360)
label rot(cycle / cyl)
label rot90(90.0 * units.deg)
label rot180(180.0 * units.deg)
label rot360(360.0 * units.deg)

label cyl_base(cyl / row)
label rot_base(cycle / cyl_base)

label IVL(28.0) // intake port
label EVL(28.0) // exhaust port
label IVO(50.0 * units.deg) //BBDC 52
label IVC(15.0 * units.deg) //ABDC 68
label EVO(55.0 * units.deg) //BBDC 89
label EVC(-40.0 * units.deg) //ABDC 59

label ILC(rot180 + IVC - IVO)
label ELC(rot180 + EVC - EVO)

label con_rod_mass(1500.0)
label piston_mass(1200.0)
label crank_mass(68.0) // kg
label flywheel_mass(7.0) // kg

label exhaust_delay_coeff(1.5)

public node variant_0 {
    output s1: 0.0;
    output s4: 1.0;
    output s2: 2.0;
    output s6: 3.0;
    output s3: 4.0;
    output s5: 5.0;
}

