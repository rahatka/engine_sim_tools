import "engine_sim.mr"
import "../../fuel/diesel.mr"

units units()
constants constants()

label bore(228.6) // 9
label stroke(266.7) // 10 1/2
label compression_ratio(11.75)
label con_rod(533.4) // 21
label compression_height(196.85 * units.mm) // 7 3/4
label intake_valve_diameter(72.39) // 2.85
label exhaust_valve_diameter(72.39) // 2.85
label intake_valves(2.0)
label exhaust_valves(2.0)

label redline(1180.0) // RPM overspeed trip set point

label cyl(12.0)
label row(2.0)
label cycle(720.0 * units.deg)
label rot(cycle / cyl)
label rot90(90.0 * units.deg)
label rot180(180.0 * units.deg)
label rot360(360.0 * units.deg)
label vee(45.0 * units.deg)

label cyl_base(cyl / row)
label rot_base(cycle / cyl_base)

label IVL(15.24) // .600 ?
label EVL(15.24) // .600 ?

// 1952 - 1954
label IVO(41.0 * units.deg) //BTDC
label IVC(53.0 * units.deg) //ABDC
label EVO(53.0 * units.deg) //BBDC
label EVC(41.0 * units.deg) //ATDC

// // 1954 - 1955
// label IVO(41.467 * units.deg) //BTDC
// label IVC(60.000 * units.deg) //ABDC
// label EVO(63.800 * units.deg) //BBDC
// label EVC(29.667 * units.deg) //ATDC

label intake_duration(IVO + IVC + rot180)
label exhaust_duration(EVO + EVC + rot180)

label ILC((rot180 - IVO + IVC) / 2.0 + rot360)
label ELC((rot180 - EVO + EVC) / 2.0 + rot180)

label piston_mass(20.8652 * units.kg) // ? 46lb
label con_rod_mass(20.8652 * units.kg) // ? 46lb
label crank_mass(800.0) // ?
label flywheel_mass(200.0) // kg

label exhaust_delay_coeff(1.5)

public node variant_0 {
    output s1: 0;
    output s4: 1;
    output s2: 2;
    output s6: 3;
    output s3: 4;
    output s5: 5;
}

