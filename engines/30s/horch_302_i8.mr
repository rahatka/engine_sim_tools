import "engine_sim.mr"
import "../../fuel/30.mr"

units units()
constants constants()

label bore(87.0)
label stroke(104.0)
label compression_ratio(6.0)
label con_rod(208.0) // ?
label compression_height(bore / 2 * units.mm) // ?
label intake_valve_diameter(33.0) // ?
label exhaust_valve_diameter(33.0) // ?
label intake_valves(1.0)
label exhaust_valves(1.0)

label redline(3600.0) // RPM

label cyl(8.0)
label row(1.0)
label cycle(720.0 * units.deg)
label cyl_base(cyl / row)
label rot_base(cycle / cyl_base)
label rot90(90.0 * units.deg)
label rot180(180.0 * units.deg)
label rot360(360.0 * units.deg)
label rot(cycle / cyl)

// ?
label IVL(7.0) // ?
label EVL(7.0) // ?
label IVO(8.0 * units.deg) //BTDC
label IVC(52.0 * units.deg) //ABDC ?
label EVO(54.0 * units.deg) //BBDC ?
label EVC(6.0 * units.deg) //ATDC

label intake_duration(IVO + IVC + rot180)
label exhaust_duration(EVO + EVC + rot180)

label ILC((rot180 - IVO + IVC) / 2.0 + rot360)
label ELC((rot180 - EVO + EVC) / 2.0 + rot180)

label con_rod_mass(750.0) // ?
label piston_mass(500.0) // ?
label crank_mass(25.0) // kg
label flywheel_mass(6.0) // kg

label exhaust_delay_coeff(1.5)

public node variant_0 {
    output s1: 0;
    output s4: 1;
    output s7: 2;
    output s3: 3;
    output s8: 4;
    output s5: 5;
    output s2: 6;
    output s6: 7;
}

