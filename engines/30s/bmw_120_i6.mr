import "engine_sim.mr"
import "../../fuel/30.mr"

units units()
constants constants()

label bore(66.0)
label stroke(96.0)
label compression_ratio(6.0) // 7.5 328
label con_rod(164.0)
label compression_height(43.5 * units.mm) // 43,5 + 14,5 mm
label intake_valve_diameter(31.0) // 36 328
label exhaust_valve_diameter(31.0) // 33 328
label intake_valves(1.0)
label exhaust_valves(1.0)

label cyl(6.0)
label row(1.0)
label cycle(720.0 * units.deg)
label rot(cycle / cyl)
label rot90(90.0 * units.deg)
label rot180(180.0 * units.deg)
label rot360(360.0 * units.deg)

label cyl_base(cyl / row)
label rot_base(cycle / cyl_base)

label redline(4000.0) // RPM

// BMW 321
label IVL(7.0) // ?
label EVL(7.0) // ?
label IVO(20.0 * units.deg) //BTDC
label IVC(56.0 * units.deg) //ABDC 18.5
label EVO(54.0 * units.deg) //BBDC 18.5
label EVC(22.0 * units.deg) //ATDC

label intake_duration(IVO + IVC + rot180)
label exhaust_duration(EVO + EVC + rot180)

label ILC((rot180 - IVO + IVC) / 2.0 + rot360)
label ELC((rot180 - EVO + EVC) / 2.0 + rot180)

label piston_mass(300.0) // ?
label con_rod_mass(446.0)
label crank_mass(12) // ? kg
label flywheel_mass(4.0) // kg

label exhaust_delay_coeff(1.5)

public node variant_0 {
    output s1: 0;
    output s5: 1;
    output s3: 2;
    output s6: 3;
    output s2: 4;
    output s4: 5;
}

