import "engine_sim.mr"
import "../../fuel/30.mr"

units units()
constants constants()

label bore(82.55) // 3 1/4
label stroke(101.6) // 4
label compression_ratio(5.05) // 1932 5.05 140; 1933 6.0 185; 1936 6.4 185
label con_rod(252.3744) // 9.936
label compression_height(59.3344 * units.mm) // ?
label intake_valve_diameter(42.0687) // 1 21/32
label exhaust_valve_diameter(39.6875) // 1 9/16
label intake_valves(1.0)
label exhaust_valves(1.0)

label redline(3250.0) // RPM

label cyl(12.0)
label row(2.0)
label cycle(720.0 * units.deg)
label rot(cycle / cyl)
label cyl_base(cyl / row)
label rot_base(cycle / cyl_base)
label rot90(90.0 * units.deg)
label rot180(180.0 * units.deg)
label rot360(360.0 * units.deg)
label vee(80.0 * units.deg)

// Pierce-Arrow V12 1932
label IVL(7.9248) // .312
label EVL(7.9248) // .312
label IVO(4.0 * units.deg) //BTDC
label IVC(52.0 * units.deg) //ABDC
label EVO(40.0 * units.deg) //BBDC
label EVC(16.0 * units.deg) //ATDC

label intake_duration(IVO + IVC + rot180)
label exhaust_duration(EVO + EVC + rot180)

label ILC((rot180 - IVO + IVC) / 2.0 + rot360)
label ELC((rot180 - EVO + EVC) / 2.0 + rot180)

label con_rod_mass(1100.0) // ?
label piston_mass(600.0) // ?
label crank_mass(55.0) // ?
label flywheel_mass(12.0) // kg

label exhaust_delay_coeff(1.5)

