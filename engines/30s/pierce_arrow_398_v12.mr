intake_lobe_profile intake_lobe_profile()
exhaust_lobe_profile exhaust_lobe_profile()

intake_flow intake_flow()
exhaust_flow exhaust_flow()

private node add_lobes {
    input base;
    input shift: 0.0;
    input this;
    alias output __out: this;

    this.add_lobe(base + 0 * rot * row + shift)
    this.add_lobe(base + 4 * rot * row + shift)
    this.add_lobe(base + 2 * rot * row + shift)
    this.add_lobe(base + 5 * rot * row + shift)
    this.add_lobe(base + 1 * rot * row + shift)
    this.add_lobe(base + 3 * rot * row + shift)
}

public node bank_builder {
    input angle;
    input phasing;
    input ignition;
    input intake;
    input exhaust;
    input pls;
    input sh;

    input rj0;
    input rj1;
    input rj2;
    input rj3;
    input rj4;
    input rj5;

    input flip: false;

    output bank: _b0;

    ignition_wire _wire1()
    ignition_wire _wire2()
    ignition_wire _wire3()
    ignition_wire _wire4()
    ignition_wire _wire5()
    ignition_wire _wire6()

    piston_parameters piston_params(
        mass: piston_mass * units.g,
        blowby: k_28inH2O(0.026),
        compression_height: compression_height,
        wrist_pin_position: 0.0,
        displacement: 0.0
    )

    connecting_rod_parameters cr_params(
        mass: con_rod_mass * units.g,
        moment_of_inertia: rod_moment_of_inertia(
            mass: con_rod_mass * units.g,
            length: con_rod * units.mm
        ),
        center_of_mass: 0.0,
        length: con_rod * units.mm
    )

    cylinder_bank_parameters bank_params(
        bore: bore * units.mm,
        deck_height: (con_rod + stroke / 2.0) * units.mm + compression_height
    )

    camshaft _intake_cam_0(base_radius: 13.9 * units.mm, lobe_profile: intake_lobe_profile)
    camshaft _exhaust_cam_0(base_radius: 13.9 * units.mm, lobe_profile: exhaust_lobe_profile)

    _intake_cam_0.add_lobes(ILC, phasing)
    _exhaust_cam_0.add_lobes(ELC, phasing)

    ignition.connect_wire(_wire1, rot_base * 0 + phasing)
    ignition.connect_wire(_wire5, rot_base * 1 + phasing)
    ignition.connect_wire(_wire3, rot_base * 2 + phasing)
    ignition.connect_wire(_wire6, rot_base * 3 + phasing)
    ignition.connect_wire(_wire2, rot_base * 4 + phasing)
    ignition.connect_wire(_wire4, rot_base * 5 + phasing)

    cylinder_bank _b0(bank_params, angle: angle)

    _b0
    .add_cylinder(
            piston: piston(piston_params),
            connecting_rod: connecting_rod(cr_params),
            rod_journal: rj0,
            intake: intake,
            exhaust_system: exhaust,
            primary_length: pls.pl0 + sh,
            ignition_wire: _wire1
        )
    .add_cylinder(
            piston: piston(piston_params),
            connecting_rod: connecting_rod(cr_params),
            rod_journal: rj1,
            intake: intake,
            exhaust_system: exhaust,
            primary_length: pls.pl1 + sh,
            ignition_wire: _wire2
        )
    .add_cylinder(
            piston: piston(piston_params),
            connecting_rod: connecting_rod(cr_params),
            rod_journal: rj2,
            intake: intake,
            exhaust_system: exhaust,
            primary_length: pls.pl2 + sh,
            ignition_wire: _wire3
        )
    .add_cylinder(
            piston: piston(piston_params),
            connecting_rod: connecting_rod(cr_params),
            rod_journal: rj3,
            intake: intake,
            exhaust_system: exhaust,
            primary_length: pls.pl3 + sh,
            ignition_wire: _wire4
        )
    .add_cylinder(
            piston: piston(piston_params),
            connecting_rod: connecting_rod(cr_params),
            rod_journal: rj4,
            intake: intake,
            exhaust_system: exhaust,
            primary_length: pls.pl4 + sh,
            ignition_wire: _wire5
        )
    .add_cylinder(
            piston: piston(piston_params),
            connecting_rod: connecting_rod(cr_params),
            rod_journal: rj5,
            intake: intake,
            exhaust_system: exhaust,
            primary_length: pls.pl5 + sh,
            ignition_wire: _wire6
        )
    .set_cylinder_head(
        head(
            intake_camshaft: _intake_cam_0,
            exhaust_camshaft: _exhaust_cam_0,
            flip_display: flip
        )
    )
}

private node add_flow_sample {
    input lift;
    input flow;
    input this;
    alias output __out: this;

    this.add_sample(lift * units.mm, k_28inH2O(flow))
}

public node head {
    // port_flow.py v1.7
    // intake port area: 10.4 cm²; saturated lift: 8.83 mm
    // exhaust port area: 9.3 cm²; saturated lift: 8.33 mm
    // cylinder volume: 543.8 cm³ (33.18 CI); engine volume: 6.525 L (398.20 CI)
    // chamber volume: 134.3 cm³ (8.19 CI); conrod/stroke 2.484; N.A.C.C. 50.70
    // 16 harmonic intake runner length: 29.3 cm; diameter: 3.1 cm
    // primary length: 4.1 cm, area: 10.2 cm², diameter: 3.6 cm
    // collector diameter: 6.8 cm, area: 36.8 cm²


    input intake_camshaft;
    input exhaust_camshaft;
    input flip_display: false;
    
    alias output __out: head;
    generic_cylinder_head head(
        chamber_volume: 134.265 * units.cc,
        intake_runner_volume: 220.7 * units.cc,
        intake_runner_cross_section_area: 7.5 * units.cm2,
        exhaust_runner_volume: 73.6 * units.cc,
        exhaust_runner_cross_section_area: 10.2 * units.cm2,

        intake_port_flow: intake_flow,
        exhaust_port_flow: exhaust_flow,
        valvetrain: standard_valvetrain(
            intake_camshaft: intake_camshaft,
            exhaust_camshaft: exhaust_camshaft
        ),
        flip_display: flip_display
    )
}

public node eng {
    alias output __out: engine;

    engine engine(
        name: "Pierce Arrow 53",
        starter_torque: 150 * units.Nm,
        starter_speed: 300 * units.rpm,
        redline: redline * units.rpm,
        fuel: s30(),
        throttle_gamma: 1.5,
        jitter: 0.8,
        noise: 0.2,
        hf_gain: 0.008,
        simulation_frequency: 8000,
        dyno_min_speed: 500 * units.rpm
    )

    label crank_moment(disk_moment_of_inertia(mass: crank_mass * units.kg, radius: (stroke / 2.0) * units.mm))
    label flywheel_moment(disk_moment_of_inertia(mass: flywheel_mass * units.kg, radius: (stroke * 3.5) * units.mm))
    label other_moment(disk_moment_of_inertia(mass: 1 * units.kg, radius: 1.0 * units.cm))

    crankshaft c0(
        throw: (stroke / 2.0) * units.mm,
        flywheel_mass: flywheel_mass * units.kg,
        mass: crank_mass * units.kg,
        friction_torque: 9.8 * units.Nm,
        moment_of_inertia: crank_moment + flywheel_moment + other_moment,
        position_x: 0.0,
        position_y: 0.0,
        tdc: 0.0
    )

    rod_journal rj0(angle: rot * 0 + rot90 + vee / 2)
    rod_journal rj1(angle: rot * 8 + rot90 + vee / 2)
    rod_journal rj2(angle: rot * 4 + rot90 + vee / 2)
    rod_journal rj3(angle: rot * 10 + rot90 + vee / 2)
    rod_journal rj4(angle: rot * 2 + rot90 + vee / 2)
    rod_journal rj5(angle: rot * 6 + rot90 + vee / 2)
    
    c0
        .add_rod_journal(rj0)
        .add_rod_journal(rj1)
        .add_rod_journal(rj2)
        .add_rod_journal(rj3)
        .add_rod_journal(rj4)
        .add_rod_journal(rj5)

    ignition_module ignition(timing_curve: timing_curve, rev_limit: 4000 * units.rpm, limiter_duration: 0.01)

    exh_setup_0 exh()

    bank_builder bank0(
        angle: vee / 2.0,
        phasing: 0.0 * units.deg,
        ignition: ignition,
        intake: intake,
        exhaust: exh.ex0,
        pls: exh,
        sh: 0,
        rj0: rj0,
        rj1: rj1,
        rj2: rj2,
        rj3: rj3,
        rj4: rj4,
        rj5: rj5,
        flip: true
    )

    bank_builder bank1(
        angle: -vee / 2.0,
        phasing: vee + rot360,
        ignition: ignition,
        intake: intake,
        exhaust: exh.ex1,
        pls: exh,
        sh: exh.sh,
        rj0: rj0,
        rj1: rj1,
        rj2: rj2,
        rj3: rj3,
        rj4: rj4,
        rj5: rj5
    )

    intake intake(
        plenum_volume: 3.1 * units.L,
        plenum_cross_section_area: 45.1 * units.cm2,
        runner_length: 29.3 * units.cm,
        intake_flow_rate: k_carb(362.3),
        idle_flow_rate: k_carb(0.001),
        idle_throttle_plate_position: 0.995,
        runner_flow_rate: k_carb(61.9),
        velocity_decay: 0.05
    )

    function timing_curve(216.7 * units.rpm)
    timing_curve
        .add_sample(0.0 * units.rpm, 8.3 * units.deg)
        .add_sample(216.7 * units.rpm, 8.3 * units.deg)
        .add_sample(433.3 * units.rpm, 8.3 * units.deg)
        .add_sample(650.0 * units.rpm, 8.8 * units.deg)
        .add_sample(866.7 * units.rpm, 10.9 * units.deg)
        .add_sample(1083.3 * units.rpm, 12.9 * units.deg)
        .add_sample(1300.0 * units.rpm, 14.7 * units.deg)
        .add_sample(1516.7 * units.rpm, 16.4 * units.deg)
        .add_sample(1733.3 * units.rpm, 17.9 * units.deg)
        .add_sample(1950.0 * units.rpm, 19.2 * units.deg)
        .add_sample(2166.7 * units.rpm, 20.5 * units.deg)
        .add_sample(2383.3 * units.rpm, 21.6 * units.deg)
        .add_sample(2600.0 * units.rpm, 22.7 * units.deg)
        .add_sample(2816.7 * units.rpm, 23.6 * units.deg)
        .add_sample(3033.3 * units.rpm, 24.5 * units.deg)
        .add_sample(3250.0 * units.rpm, 25.3 * units.deg)
        .add_sample(3466.7 * units.rpm, -12.5 * units.deg)
        .add_sample(3683.3 * units.rpm, -25.0 * units.deg)

    engine
        .add_crankshaft(c0)
        .add_cylinder_bank(bank0.bank)
        .add_cylinder_bank(bank1.bank)
        .add_ignition_module(ignition)
}

private node exh_setup_0 {
    output ex0: _ex0;
    output ex1: _ex0;

    output pl0: _pl0;
    output pl1: _pl1;
    output pl2: _pl2;
    output pl3: _pl3;
    output pl4: _pl4;
    output pl5: _pl5;

    output sh: _sh;

    label spacing_factor(1.25)
    label flange_density(1.0 * exhaust_delay_coeff)
    label collector_cross_section_area(36.8)
    label exhaust_pipe_length_0(400.0) // cm
    label exhaust_volume_0(collector_cross_section_area * exhaust_pipe_length_0 / 1000.0) // Litres

    float _sh((35.0 / flange_density) * units.cm)
    label _pl0 ((6.50 * bore * spacing_factor / flange_density) * units.mm)
    label _pl1 ((4.79 * bore * spacing_factor / flange_density) * units.mm)
    label _pl2 ((4.53 * bore * spacing_factor / flange_density) * units.mm)
    label _pl3 ((2.96 * bore * spacing_factor / flange_density) * units.mm)
    label _pl4 ((2.70 * bore * spacing_factor / flange_density) * units.mm)
    label _pl5 ((1.00 * bore * spacing_factor / flange_density) * units.mm)

    exhaust_system_parameters es_params(
        outlet_flow_rate: k_carb(611.4),
        collector_cross_section_area: 36.8 * units.cm2,
        length: exhaust_pipe_length_0 * units.cm,
        primary_tube_length: 4.1 * units.cm,
        primary_flow_rate: k_carb(103.2),
        velocity_decay: 0.2,
        audio_volume: 0.0005,
        volume: (exhaust_volume_0 + 8.0) * units.L
    )

    exhaust_system _ex0(es_params, impulse_response: impulse_response(filename: "../../impulse_responses/smooth_56.wav"))
}

// 1933 Silver Arrow
public node veh {
    alias output __out: vehicle;
    vehicle vehicle(
        mass: 2414.0 * units.kg, // 2314 curb
        drag_coefficient: 0.48,
        cross_sectional_area: (1560 * units.mm) * (1500 * units.mm), // ?
        diff_ratio: 4.21, // 4.45 Series 80, 26% OD
        tire_radius: (825.5 / 2) * units.mm, // 7.5x17 ?
        rolling_resistance: 20
        )
}

// 1933 Silver Arrow
private node trn {
    alias output __out:
        transmission(
            max_clutch_torque: 600 * units.Nm,
            max_clutch_flex: 10 * units.deg,
            limit_clutch_flex: true,
            clutch_stiffness: 20 * units.Nm / units.deg,
            clutch_damping: 2.0,
            simulate_flex: true
        )
        .add_gear(2.83)
        .add_gear(1.70)
        .add_gear(1.00)
        .add_gear(1.00 * 0.74); // 3rd overdrive
}

run(
    engine: eng(),
    transmission: trn(),
    vehicle: veh()
)