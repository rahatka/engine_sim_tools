import "engine_sim.mr"
units units()

public node s50 { // 50s standard
    alias output __out: f;
    fuel f(
        max_turbulence_effect: 8.5,
        burning_efficiency_randomness: 0.07,
        max_burning_efficiency: 0.8,
        molecular_mass: 83.0 * units.g,
        energy_density: 46.3 * units.MJ / units.kg,
        density: 0.755 * units.kg / units.L,
        molecular_afr: 14.7,
        low_efficiency_attenuation: 0.7,
        max_dilution_effect: 4.5,
        turbulence_to_flame_speed_ratio:
        function(5.0) // steepness 0.9
            .add_sample(0.0, 20.0)
            .add_sample(5.0, 33.5)
            .add_sample(10.0, 45.3)
            .add_sample(15.0, 56.4)
            .add_sample(20.0, 67.2)
            .add_sample(25.0, 77.7)
            .add_sample(30.0, 87.9)
            .add_sample(35.0, 98.1)
            .add_sample(40.0, 108.0)
            .add_sample(45.0, 117.9)
            .add_sample(50.0, 127.6)
            .add_sample(55.0, 137.2)
            .add_sample(60.0, 146.8)
            .add_sample(65.0, 156.3)
            .add_sample(70.0, 165.7)
            .add_sample(75.0, 175.0)
    )
}
